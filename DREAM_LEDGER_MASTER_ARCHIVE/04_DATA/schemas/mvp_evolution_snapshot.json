{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DREAMLedger_MVP_Evolution_Snapshot",
  "description": "至高務實版：七層生命閉環與雙軸品質審計的最小可用資料結構 (Risk Map v5)",
  "type": "object",
  "required": [
    "event_id", 
    "timestamp", 
    "observation_layer", 
    "interpretation_layer", 
    "policy_layer", 
    "outcome_layer", 
    "decision_quality_axis", 
    "assumption_audit_layer"
  ],
  "properties": {
    "event_id": { 
      "type": "string", 
      "description": "唯一事件焊接碼，如 EVT-20260607-CreditLoan" 
    },
    "timestamp": { 
      "type": "string", 
      "format": "date-time",
      "description": "事件物理發生或刻印的時空戳記"
    },
    "observation_layer": {
      "type": "object",
      "required": ["observation"],
      "properties": {
        "observation": { 
          "type": "string", 
          "description": "L1 Observation: 物理世界客觀觀測到的事實碎片，拒絕CRUD，採自然語義" 
        }
      }
    },
    "interpretation_layer": {
      "type": "object",
      "required": ["belief", "interpretation", "significance"],
      "properties": {
        "belief": { 
          "type": "string", 
          "description": "L2 Belief: 當下被大腦情緒、認知模型受限的主觀信仰（例如：我快破產了）" 
        },
        "interpretation": { 
          "type": "string", 
          "description": "L3 Interpretation: 後來跨越時空、多視角的考古再詮釋（後見之明）" 
        },
        "significance": { 
          "type": "string", 
          "description": "L4 Significance: 穿過重要性剪裁後沉澱的核心洞察，嚴防意義膨脹症" 
        }
      }
    },
    "policy_layer": {
      "type": "object",
      "required": ["policy_id", "policy", "status"],
      "properties": {
        "policy_id": { 
          "type": "string",
          "description": "策略唯一識別碼，如 PLC-2026-LEVERAGE-GUARD"
        },
        "policy": { 
          "type": "string", 
          "description": "L5 Policy: 為了指引未來而提煉的原子行為方針、Guardrail 或 Checklist" 
        },
        "status": { 
          "type": "string", 
          "enum": ["active", "stale", "overruled"],
          "description": "政策法律狀態：生效中、陳舊、被推翻"
        }
      }
    },
    "outcome_layer": {
      "type": "object",
      "required": ["outcome", "policy_ref"],
      "properties": {
        "outcome": { 
          "type": "string", 
          "description": "L6 Outcome: 此方針在物理世界落地後引發的真實結果與代價，擁有推翻Policy的審判權" 
        },
        "policy_ref": { 
          "type": "string", 
          "description": "關聯受物理結果審判的 L5 Policy ID" 
        }
      }
    },
    "decision_quality_axis": {
      "type": "object",
      "required": ["dq_grade", "information_score", "guardrail_score", "emotion_score"],
      "properties": {
        "dq_grade": { 
          "type": "string", 
          "enum": ["A", "B", "C", "D"], 
          "description": "橫向品質軸：完全獨立於隨機結果的當下決策流程品質（Process Quality）" 
        },
        "information_score": { 
          "type": "number", 
          "minimum": 0, 
          "maximum": 1, 
          "description": "決策當下資訊是否充分、關鍵邊界假設是否查驗評分" 
        },
        "guardrail_score": { 
          "type": "number", 
          "minimum": 0, 
          "maximum": 1, 
          "description": "是否嚴格遵守既有的行為 Policy 與冷靜期流程評分" 
        },
        "emotion_score": { 
          "type": "number", 
          "minimum": 0, 
          "maximum": 1, 
          "description": "大腦心智模型當時受到焦慮、恐懼或貪婪污染的指數（越低越理智）" 
        }
      }
    },
    "assumption_audit_layer": {
      "type": "object",
      "required": ["audit_verdict", "crushed_assumptions"],
      "properties": {
        "audit_verdict": { 
          "type": "string", 
          "description": "L7 Assumption Audit: 核心模型審計結論。不看流程正義，直擊世界模型哪裡出錯" 
        },
        "crushed_assumptions": {
          "type": "array",
          "description": "埋在決策基岩底下的原子假設死亡紀錄名冊",
          "items": {
            "type": "object",
            "required": ["assumption_id", "statement", "status", "confidence_delta"],
            "properties": {
              "assumption_id": { "type": "string" },
              "statement": { 
                "type": "string", 
                "description": "當時深信不疑的世界模型基本假設陳述" 
              },
              "status": { 
                "type": "string",
                "enum": ["verified", "invalidated", "replaced"],
                "description": "假設目前的生命存活狀態"
              },
              "confidence_delta": { 
                "type": "string", 
                "description": "信任度跨時空熔斷位移紀錄，例如 0.85 -> 0.15" 
              }
            }
          }
        }
      }
    }
  }
}